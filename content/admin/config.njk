---
permalink: /admin/config.yml
eleventyExcludeFromCollections: true
layout: false
---
{# Eleventy renders this to /admin/config.yml at build time.

   Sveltia uses {{ }} for its own template variables (e.g. {{date}}, {{slug}},
   {{year}}/{{month}}-{{day}}/show in path templates). To pass those through
   literally we wrap the body in {% raw %} … {% endraw %} and break out for
   the two values we inject:
     - {{ recentWindow.pattern }} — rolling regex matching the visible date window
#}
{%- set PATTERN = recentWindow.pattern -%}
{%- set WINDOW = recentWindow.months | join(", ") -%}
{%- set GENERATED = recentWindow.generatedAt -%}
{%- set REPO = site.githubRepo -%}
{%- set BRANCH = site.githubBranch -%}
{%- set VOCAB = tagVocab.all -%}
# Sveltia CMS config for Living on Earth.
# Rendered at build time from content/admin/config.njk so the date filters
# get a fresh rolling window on every deploy.
#
# Window: {{ WINDOW }} (generated {{ GENERATED }}).
{% raw %}
backend:
  name: github
  repo: {% endraw %}{{ REPO }}{% raw %}
  branch: {% endraw %}{{ BRANCH }}{% raw %}
  # OAuth proxy (Cloudflare Worker — auth/ in the repo). With this set,
  # "Sign in with GitHub" works without a PAT; PAT login still works as
  # a fallback for editors who prefer it.
  base_url: https://loe-auth.hector-ea.workers.dev
  auth_endpoint: auth

site_url: https://vibingon.earth
display_url: https://vibingon.earth
logo_url: /theme/img/logo.png

media_folder: content/images
public_folder: /images

collections:
  - name: shows
    label: Shows
    label_singular: Show
    description: Recent show pages. Segments are auto-discovered at build time.
    folder: content/shows
    create: true
    identifier_field: title
    path: '{{year}}/{{month}}-{{day}}/show'
    summary: '{{date}} - {{title}}'
    sortable_fields:
      fields: [date, title]
      default: { field: date, direction: descending }
    filter: { field: date, pattern: '{% endraw %}{{ PATTERN }}{% raw %}' }
    extension: md

    fields:
      - { label: 'Title', name: 'title', widget: 'string', hint: 'e.g. "Living on Earth: May 22, 2026"' }
      - { label: 'Date', name: 'date', widget: 'datetime', date_format: 'YYYY-MM-DD', time_format: false }
      - { label: 'Template', name: 'template', widget: 'hidden', default: 'show' }
      - { label: 'Category', name: 'category', widget: 'hidden', default: 'Shows' }
      - { label: 'Megaphone episode ID', name: 'megaphone_id', widget: 'string', required: false, hint: 'e.g. LOE6677141098' }
      - { label: 'Header image URL', name: 'image_url', widget: 'string', required: false }
      - { label: 'Summary', name: 'summary', widget: 'text', required: false }
      - { label: 'Body', name: 'body', widget: 'markdown', required: false, hint: 'Usually empty — segments live in content/segments/ and render automatically.' }

  - name: segments
    label: Segments
    label_singular: Segment
    description: Recent story segments. Each is paired with its show by date.
    folder: content/segments
    create: true
    identifier_field: title
    path: '{{year}}/{{month}}-{{day}}/{{slug}}'
    summary: '{{date}} - {{title}}'
    sortable_fields:
      fields: [date, title]
      default: { field: date, direction: descending }
    filter: { field: date, pattern: '{% endraw %}{{ PATTERN }}{% raw %}' }
    extension: md

    fields:
      - { label: 'Title', name: 'title', widget: 'string' }
      - { label: 'Date', name: 'date', widget: 'datetime', date_format: 'YYYY-MM-DD', time_format: false, hint: 'Must match the parent show date.' }
      - { label: 'Category', name: 'category', widget: 'hidden', default: 'Segments' }
      - { label: 'Megaphone episode ID', name: 'megaphone_id', widget: 'string', required: false }
      - { label: 'Header image URL', name: 'image_url', widget: 'string', required: false }
      - { label: 'Image caption', name: 'image_caption', widget: 'string', required: false }
      - { label: 'Summary', name: 'summary', widget: 'text', required: false }
      - { label: 'Order', name: 'order', widget: 'number', required: false, hint: 'Optional. Lower numbers come first on the show page. Defaults to filename order.' }
      - { label: 'Tags', name: 'tags', widget: 'select', multiple: true, required: false, options: {% endraw %}{{ VOCAB | dump | safe }}{% raw %}, hint: 'Pick from the controlled vocabulary at /tags.html. Empty is OK if nothing fits.' }
      - { label: 'Body', name: 'body', widget: 'markdown' }

  - name: newsletters
    label: Newsletters
    label_singular: Newsletter
    folder: content/newsletters
    create: true
    identifier_field: title
    slug: '{{year}}-{{month}}-{{day}}-{{slug}}'
    sortable_fields:
      fields: [date, title]
      default: { field: date, direction: descending }
    extension: md

    fields:
      - { label: 'Title', name: 'title', widget: 'string' }
      - { label: 'Date', name: 'date', widget: 'datetime', date_format: 'YYYY-MM-DD', time_format: false }
      - { label: 'Slug', name: 'slug', widget: 'string', hint: 'URL slug, e.g. "fire-we-can-walk-beside"' }
      - { label: 'Category', name: 'category', widget: 'hidden', default: 'Newsletter' }
      - { label: 'Template', name: 'template', widget: 'hidden', default: 'newsletter_article' }
      - { label: 'Summary', name: 'summary', widget: 'string', required: false }
      - { label: 'Body', name: 'body', widget: 'markdown' }

  - name: pages
    label: Pages
    label_singular: Page
    description: Standalone site pages (About, Stations, etc.).
    folder: content/pages
    create: false
    identifier_field: title
    extension: md
    fields:
      - { label: 'Title', name: 'title', widget: 'string' }
      - { label: 'Slug', name: 'slug', widget: 'string', required: false }
      - { label: 'Status', name: 'status', widget: 'string', required: false }
      - { label: 'Body', name: 'body', widget: 'markdown' }
{% endraw %}
