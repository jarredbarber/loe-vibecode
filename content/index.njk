---
layout: layouts/base.njk
permalink: /index.html
eleventyExcludeFromCollections: true
---
{% from "modules/audio-player.njk" import player with context %}
<style>
.on-this-day {
    /* Match .featured-show shell so the two callouts feel like a set. */
    max-width: 800px;
    width: 100%;
    box-sizing: border-box;
    margin: 1.5em auto;
    padding: 1.25em 1.5em;
    border-left: 4px solid #6a8a3f;
    border-radius: 8px;
    background: rgba(244, 241, 232, 0.7);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}
.on-this-day h2 {
    margin: 0 0 .5em;
    font-size: 1.15em;
}
.on-this-day ul {
    list-style: none;
    margin: 0;
    padding: 0;
}
.on-this-day li {
    padding: .4em 0;
    border-top: 1px solid #e0dcd0;
}
.on-this-day li:first-child { border-top: 0; }
.on-this-day li p {
    margin: .25em 0 0;
    font-size: .92em;
    color: #444;
}
.on-this-day-date {
    color: #777;
    font-size: .85em;
    margin-left: .5em;
}
</style>
{% set latest = collections.shows[0] %}
{% set recent = collections.shows.slice(1, 6) %}
<div class="body">
    <div class="body_resize">
        {% if latest %}
        <div class="featured-show">
            <h1>This Week on <i>Living on Earth</i></h1>
            <h2><a href="{{ site.url }}{{ latest.url }}">
                {{ latest.data.date | strftime('%B') }} {{ latest.data.date | dayOrdinal }}, {{ latest.data.date | strftime('%Y') }}
            </a></h2>
            <div class="featured-content">
                {% if latest.data.banner_url or latest.data.image_url %}
                <img src="{{ latest.data.banner_url or latest.data.image_url }}" alt="{{ latest.data.title }}" class="featured-image" />
                {% endif %}
                {% if latest.data.summary %}
                <p class="featured-summary">{{ latest.data.summary }}{% if latest.data.length %} <span class="show-length">({{ latest.data.length }})</span>{% endif %}</p>
                {% endif %}
                {% set thisWeekSegments = (latest | segmentsForShow(collections.segments)) %}
                {% if thisWeekSegments.length %}
                <div class="featured-segments">
                    <strong>This Week:</strong>
                    {% for segment in thisWeekSegments %}
                    <a href="{{ site.url }}{{ segment.url }}">{{ segment.data.title }}</a>{% if not loop.last %} | {% endif %}
                    {% endfor %}
                </div>
                {% endif %}
                <div style="clear: both;"></div>
            </div>
            {% if latest.data.megaphone_id %}
            {{ player([{ id: latest.data.megaphone_id, title: latest.data.title, art: latest.data.image_url or latest.data.banner_url }], true, latest.data.megaphone_id, [], true) }}
            {% endif %}
            <p><a href="{{ site.url }}{{ latest.url }}" class="read-more-btn">View Full Show →</a></p>
        </div>

        {% if onThisDay.picks.length %}
        <section class="on-this-day">
            <h2>This week in <em>Living on Earth</em> history</h2>
            <ul>
            {% for p in onThisDay.picks %}
                <li>
                    <a href="{{ site.url }}{{ p.url }}">{{ p.title }}</a>
                    <span class="on-this-day-date">{{ p.date | strftime('%B %-d, %Y') }}</span>
                    {% if p.summary %}<p>{{ p.summary }}</p>{% endif %}
                </li>
            {% endfor %}
            </ul>
        </section>
        {% endif %}

        <h2 class="recent-shows-header">Recent Shows</h2>
        {% for show in recent %}
        <div class="blog">
            <h3><a href="{{ site.url }}{{ show.url }}">
                {{ show.data.date | strftime('%B') }} {{ show.data.date | dayOrdinal }}, {{ show.data.date | strftime('%Y') }}
            </a></h3>
            <div class="clr"></div>
            {% if show.data.thumb_url or show.data.image_url or show.data.banner_url %}
            <img src="{{ show.data.thumb_url or show.data.image_url or show.data.banner_url }}" alt="{{ show.data.title }}" class="floated" width="150" />
            {% endif %}
            <p>{{ show.data.summary }}{% if show.data.length %} <span class="show-length">({{ show.data.length }})</span>{% endif %}</p>
            <p><a href="{{ site.url }}{{ show.url }}">Read more →</a></p>
        </div>
        <div class="clr"></div>
        {% endfor %}
        {% endif %}
        <div class="clr"></div>
    </div>
</div>
