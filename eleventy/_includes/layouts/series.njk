---
layout: layouts/base.njk
---
<div class="body">
    <div class="body_resize">
        <div class="article-content">
            <h1>{{ title }}</h1>

            {% if description %}
            <p><em>{{ description }}</em></p>
            {% endif %}

            {% set headerImage = banner_url or image_url %}
            {% if headerImage %}
            <figure class="header-image-container">
                <img class="header-image" src="{{ headerImage }}" alt="{{ title }}" />
                {% if image_caption %}
                <figcaption>{{ image_caption }}</figcaption>
                {% endif %}
            </figure>
            {% endif %}

            <div class="clr"></div>

            <div class="series-content">
                {{ content | safe }}
            </div>
        </div>
        <p><a href="/features.html" class="silver">&larr; Back to Features</a> &middot; <a href="{{ site.url }}/index.html" class="silver">Home</a></p>
    </div>
    <div class="clr"></div>
</div>
