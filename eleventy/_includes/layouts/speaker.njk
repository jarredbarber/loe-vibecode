---
layout: layouts/base.njk
---
<div class="body">
    <div class="body_resize">
        <div class="article-content">
            <h1>{{ speaker.name }}</h1>
            <p class="speaker-blurb">
                {{ speaker.count }} appearance{% if speaker.count != 1 %}s{% endif %}
                on <em>Living on Earth</em>{% if speaker.earliestYear == speaker.latestYear %},
                {{ speaker.earliestYear }}{% else %},
                from {{ speaker.earliestYear }} to {{ speaker.latestYear }}{% endif %}.
            </p>
            <ul class="archive-list">
                {% for seg in speaker.segments.slice(0, 50) %}
                <li>
                    <span class="archive-date">
                        <a href="{{ site.url }}{{ seg.url }}">{{ seg.data.date | strftime('%B %d, %Y') }}</a>:
                    </span>
                    <span class="archive-segments">
                        <a href="{{ site.url }}{{ seg.url }}">{{ seg.data.title | stripQuotes }}</a>
                        {% if seg.data.summary %}
                            <p class="speaker-segment-summary">{{ seg.data.summary | safe }}</p>
                        {% endif %}
                    </span>
                </li>
                {% endfor %}
            </ul>
            {% if speaker.segments.length > 50 %}
                <p class="speaker-cap-note"><em>Showing the 50 most recent appearances out of {{ speaker.segments.length }}.</em></p>
            {% endif %}
            <p><a href="{{ site.url }}/index.html" class="silver">&larr; Back to Home</a></p>
        </div>
    </div>
    <div class="clr"></div>
</div>
