---
layout: layouts/base.njk
---
<div class="body">
    <div class="body_resize">
        <div class="article-content">
            <h1>#{{ tag.name }}</h1>
            <p class="speaker-blurb">
                {{ tag.count }} segment{% if tag.count != 1 %}s{% endif %}
                tagged with <em>{{ tag.name }}</em> on <em>Living on Earth</em>.
            </p>

            {# Frequency-over-time sparkline.
               - Year buckets by default; falls back to monthly buckets when
                 the year span is too narrow to be visually informative
                 (helpful right now — archive isn't tagged yet).
               - X-axis starts at the earliest tagged period, not 1991.
               - Bars are anchor links to the corresponding period section
                 below; clicking jumps + highlights.
               - Y-axis labels the peak; small + unobtrusive overall. #}
            {% if tag.count >= 5 and tag.yearCountsPeak %}
            {% set _spanYears = tag.yearCountsLast - tag.yearCountsFirst %}
            {% set _useMonth = _spanYears < 3 %}
            {% set _series = tag.monthCountsWithOffset if _useMonth else tag.yearCounts %}
            {% set _peak = tag.monthCountsPeak if _useMonth else tag.yearCountsPeak %}
            {% set _spanUnits = tag.monthCountsSpan if _useMonth else _spanYears %}
            {% set _periods = _spanUnits + 1 %}

            <style>
                .tag-sparkline {
                    margin: 0.5em 0 1.25em;
                    width: 100%;
                }
                /* Hybrid layout: HTML for axis labels (so fonts are normal
                   CSS and stay readable at any width), SVG only for the bars
                   themselves with preserveAspectRatio="none" so they stretch
                   horizontally to fill any container width without coupling
                   bar geometry to font geometry. */
                .tag-sparkline-row {
                    display: flex;
                    align-items: stretch;
                    height: 56px;
                    gap: 6px;
                }
                .tag-sparkline-yaxis {
                    display: flex;
                    flex-direction: column;
                    justify-content: space-between;
                    align-items: flex-end;
                    font-size: 11px;
                    color: #777;
                    font-family: 'Space Mono', monospace;
                    padding-right: 4px;
                    border-right: 1px solid #d5d8d2;
                }
                .tag-sparkline-bars {
                    flex: 1;
                    min-width: 0;
                    border-bottom: 1px solid #c5c8c2;
                }
                .tag-sparkline-bars svg {
                    display: block;
                    width: 100%;
                    height: 100%;
                }
                .tag-sparkline-bar {
                    fill: #8bb04d;
                    transition: fill 0.15s;
                    cursor: pointer;
                }
                .tag-sparkline-bar:hover { fill: #6a8a3f; }
                .tag-sparkline-xaxis {
                    display: flex;
                    justify-content: space-between;
                    font-size: 11px;
                    color: #777;
                    font-family: 'Space Mono', monospace;
                    padding-left: 32px; /* roughly matches yaxis width + gap */
                    margin: 4px 0 0;
                }
                .tag-sparkline-caption {
                    font-size: 0.78em;
                    color: #888;
                    margin: 0.5em 0 0;
                    font-family: 'Space Mono', monospace;
                }
                .tag-period-heading {
                    font-size: 1.05em;
                    color: #555;
                    margin: 1em 0 0.25em;
                    border-bottom: 1px solid #e5e8e3;
                    padding-bottom: 0.15em;
                }
            </style>
            <div class="tag-sparkline">
                <div class="tag-sparkline-row">
                    <div class="tag-sparkline-yaxis" aria-hidden="true">
                        <span>{{ _peak }}</span>
                        <span>0</span>
                    </div>
                    <div class="tag-sparkline-bars">
                        {# viewBox uses simple 0-100 coords; preserveAspectRatio
                           none lets bars stretch horizontally to whatever width
                           the container is. Heights in viewBox are 0-100; each
                           bar's height = (count/peak)*100. #}
                        <svg viewBox="0 0 {{ _periods }} 100" preserveAspectRatio="none"
                            xmlns="http://www.w3.org/2000/svg" role="img"
                            aria-label="Segments tagged {{ tag.name }} over time">
                            {% for d in _series %}
                            {% set _offset = d.offset if _useMonth else (d.year - tag.yearCountsFirst) %}
                            {% set _h = (d.count / _peak) * 100 %}
                            {% set _y = 100 - _h %}
                            {% set _yearStr = (d.month | string).slice(0, 4) if _useMonth else (d.year | string) %}
                            {% set _anchor = 'period-' + _yearStr %}
                            {% set _label = d.month if _useMonth else (d.year | string) %}
                            <a href="#{{ _anchor }}">
                                <rect class="tag-sparkline-bar" x="{{ _offset + 0.1 }}" y="{{ _y }}" width="0.8" height="{{ _h }}">
                                    <title>{{ _label }}: {{ d.count }} segment{% if d.count != 1 %}s{% endif %}</title>
                                </rect>
                            </a>
                            {% endfor %}
                        </svg>
                    </div>
                </div>
                {% if _series.length %}
                {% set _firstLabel = _series[0].month if _useMonth else (_series[0].year | string) %}
                {% set _lastLabel = _series[_series.length - 1].month if _useMonth else (_series[_series.length - 1].year | string) %}
                <div class="tag-sparkline-xaxis" aria-hidden="true">
                    <span>{{ _firstLabel }}</span>
                    {% if _firstLabel != _lastLabel %}<span>{{ _lastLabel }}</span>{% endif %}
                </div>
                {% endif %}
                <p class="tag-sparkline-caption">peak: {{ _peak }} segment{% if _peak != 1 %}s{% endif %} in a {% if _useMonth %}month{% else %}year{% endif %} · click a bar to jump</p>
            </div>
            {% endif %}

            {# Segments list, grouped by year — month-granularity in the chart
               would be too noisy as a list of headings. Each year section's
               anchor matches the chart's bar link target. #}
            {% set _grpFmt = '%Y' %}
            {% set _prevGroup = '' %}
            <ul class="archive-list">
                {% for seg in tag.segments %}
                {% set _group = seg.data.date | strftime(_grpFmt) %}
                {% if _group != _prevGroup %}
                {% if _prevGroup != '' %}</ul>{% endif %}
                <h3 class="tag-period-heading" id="period-{{ _group }}">{{ _group }}</h3>
                <ul class="archive-list">
                {% set _prevGroup = _group %}
                {% endif %}
                <li>
                    <span class="archive-date">
                        <a href="{{ site.url }}{{ seg.url }}">{{ seg.data.date | strftime('%B %d, %Y') }}</a>:
                    </span>
                    <span class="archive-segments">
                        <a href="{{ site.url }}{{ seg.url }}">{{ seg.data.title | stripQuotes }}</a>
                        {% if seg.data.summary %}
                            <p class="speaker-segment-summary">{{ seg.data.summary | safe }}</p>
                        {% endif %}
                    </span>
                </li>
                {% endfor %}
            </ul>
            <p>
                <a href="{{ site.url }}/tags.html" class="silver">&larr; All tags</a>
                &nbsp;·&nbsp;
                <a href="{{ site.url }}/index.html" class="silver">Back to Home</a>
            </p>
        </div>
    </div>
    <div class="clr"></div>
</div>
