{# Build-time audio player — replaces the Megaphone iframe with a site-styled
   player. Wiring (play, scrub, resume, deep-link, clip, chapter auto-advance)
   lives in static/js/episode-player.js, which reads track ids from the
   .ep-chap nodes. Theming uses the site CSS variables, so dark mode is
   automatic. The audio source is the episode's enclosure mp3
   (traffic.megaphone.fm/<id>.mp3), which preserves Megaphone's dynamic ad
   insertion + download counting.

   tracks     — list of { id, title }  (megaphone_id + display title)
   single     — true for one-track pages (hides the chapter list)
   fallbackId — megaphone_id used in a <noscript> iframe fallback #}
{% macro player(tracks, single=false, fallbackId="") %}
{% if tracks and tracks.length %}
<div class="episode-player{% if single %} episode-player--single{% endif %}" aria-label="Episode audio player">
    <div class="ep-row">
        <img class="ep-logo" src="{{ site.url }}/theme/img/logo.png" alt="Living on Earth">
        <button class="ep-play" type="button" aria-label="Play">▶</button>
        <div class="ep-mid">
            <div class="ep-now"></div>
            <div class="ep-bar" role="slider" aria-label="Seek" tabindex="0"><div class="ep-buf"></div><div class="ep-fill"></div></div>
            <div class="ep-meta"><span class="ep-cur">0:00</span><span class="ep-dur">--:--</span></div>
        </div>
        <div class="ep-tools">
            <button class="ep-tool ep-spd" type="button" aria-label="Playback speed">1&times;</button>
            <button class="ep-tool ep-share" type="button" aria-label="Copy link at current time">&#128279;</button>
            <button class="ep-tool ep-clip" type="button" aria-label="Clip an excerpt to share">&#9986;</button>
        </div>
    </div>
    <ul class="ep-chaps">
        {% for t in tracks %}
        <li class="ep-chap" data-id="{{ t.id }}" data-i="{{ loop.index0 }}"><span class="ep-chap-n">{{ loop.index }}</span><span class="ep-chap-t">{{ t.title | stripQuotes }}</span></li>
        {% endfor %}
    </ul>
    {% if fallbackId %}<noscript><iframe frameborder="0" height="200" scrolling="no" width="100%" src="https://player.megaphone.fm/{{ fallbackId }}?light=true"></iframe></noscript>{% endif %}
</div>
{% endif %}
{% endmacro %}
