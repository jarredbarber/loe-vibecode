{# Segment card rendered inside show.njk. Caller sets `segment` to an
   Eleventy item; we pull metadata from its frontmatter. #}
<div class="show-segment">
    <h3><a href="{{ segment.url }}">{{ segment.data.title }}</a></h3>

    {% set _readTime = segment.templateContent | readingTime %}
    {% set _listenTime = segment.templateContent | listeningTime %}
    {% if _readTime or _listenTime %}
    <p class="segment-time">
        {% if _readTime %}{{ _readTime }}{% endif %}
        {% if _readTime and _listenTime %}<span class="segment-time-sep">·</span>{% endif %}
        {% if _listenTime %}{{ _listenTime }}{% endif %}
    </p>
    {% endif %}

    {% if segment.data.banner_url or segment.data.image_url %}
    <div class="segment-image">
        <img src="{{ segment.data.banner_url or segment.data.image_url }}" alt="{{ segment.data.title }}">
    </div>
    {% endif %}

    <div class="segment-content">
        {% if segment.data.megaphone_id %}
        <div class="segment-player">
            <iframe frameborder="0" height="200" scrolling="no" width="100%"
                src="https://player.megaphone.fm/{{ segment.data.megaphone_id }}?light=true"></iframe>
        </div>
        {% endif %}

        {% if segment.data.summary %}
        <p>{{ segment.data.summary }}{% if segment.data.length %} <span class="segment-length">({{ segment.data.length }})</span>{% endif %}</p>
        {% endif %}
    </div>
    <div class="clr"></div>
</div>
