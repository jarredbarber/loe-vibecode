<style>
    #stations-map-container {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 20px;
    }

    #map-wrapper {
        flex: 1 1 600px;
        max-width: 100%;
    }

    #stations-map-container svg {
        width: 100%;
        height: auto;
        display: block;
    }

    #stations-map-container svg path {
        fill: #d0d0d0;
        cursor: pointer;
        transition: fill 0.2s;
    }

    /* Highlight Active State Overlay */
    /* Target the <use> elements created in the highlight overlay group */
    #stations-map-container svg use.state_highlight {
        fill: #88BDBD !important;
        pointer-events: none;
        /* Ensure clicks pass through to the path below */
    }

    /* Legacy/Direct Path Highlighting (if needed for fallback) */
    #stations-map-container svg path.state-highlight,
    #stations-map-container svg circle.state-highlight,
    #stations-map-container svg path.state_highlight,
    #stations-map-container svg circle.state_highlight {
        fill: #88BDBD !important;
        /* Blue highlight */
    }

    #stations-map-container svg .borders {
        stroke: #ffffff;
        fill: none;
        pointer-events: none;
    }

    /* Fix for SVG artifacts: border paths like 'nm-tx' inherit fill, causing grey shapes */
    #stations-map-container svg path[class*="-"] {
        fill: none !important;
        stroke: #ffffff;
        stroke-width: 1px;
        pointer-events: none;
    }

    #stations-list-display {
        flex: 1 1 300px;
        background: #f9f9f9;
        padding: 20px;
        border-radius: 8px;
        border: 1px solid #eee;
        min-height: 200px;
    }

    #stations-list-display h3 {
        margin-top: 0;
        border-bottom: 2px solid #ddd;
        padding-bottom: 10px;
    }

    #stations-list-display ul {
        padding-left: 20px;
    }

    /* Hide the static panel on desktop hover-capable devices */
    @media (hover: hover) and (min-width: 701px) {
        #stations-list-display {
            display: none;
        }
    }

    /* Hovercard */
    #map-hovercard {
        position: fixed;
        z-index: 1000;
        background: var(--card-bg, #fff);
        color: var(--text, #222);
        border: 1px solid #ccc;
        border-radius: 10px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.18);
        padding: 14px 16px 12px 16px;
        max-width: 280px;
        min-width: 180px;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.12s;
        font-size: 0.95em;
    }

    #map-hovercard.visible {
        opacity: 1;
        pointer-events: auto;
    }

    #map-hovercard h3 {
        margin: 0 0 8px 0;
        font-size: 1em;
        border-bottom: 1px solid #ddd;
        padding-bottom: 6px;
        padding-right: 20px;
    }

    #map-hovercard ul {
        margin: 0;
        padding-left: 18px;
    }

    #map-hovercard li {
        margin-bottom: 3px;
    }

    #map-hovercard-close {
        position: absolute;
        top: 8px;
        right: 10px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.1em;
        line-height: 1;
        color: #888;
        padding: 0;
    }

    #map-hovercard-close:hover {
        color: #333;
    }

    /* Only show hovercard on desktop hover-capable devices */
    @media not all and (hover: hover), (max-width: 700px) {
        #map-hovercard {
            display: none !important;
        }
    }

    #zip-finder {
        margin: 20px 0;
        padding: 12px 20px;
        background: #f3f7f7;
        border: 1px solid #d6e2e2;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    #zip-finder label {
        font-weight: 600;
        white-space: nowrap;
        margin: 0;
    }

    #zip-finder input {
        font-size: 1.1em;
        padding: 6px 10px;
        width: 8em;
        border: 1px solid #b0c0c0;
        border-radius: 4px;
    }

    #zip-finder-results {
        flex-basis: 100%;
        margin-top: 4px;
    }

    #zip-finder-results h4 {
        margin: 8px 0 4px 0;
    }

    #zip-finder-results ul {
        margin: 4px 0;
        padding-left: 20px;
    }

    #zip-finder-results .zip-note {
        color: #555;
        font-size: 0.9em;
        font-style: italic;
    }
</style>

<div id="zip-finder">
    <label for="zip-input">Find your nearest station</label>
    <input id="zip-input" type="text" inputmode="numeric" maxlength="5" placeholder="Zip code" autocomplete="postal-code">
    <div id="zip-finder-results" aria-live="polite"></div>
</div>

<div id="stations-map-container">
    <div id="map-wrapper">
        <!-- SVG Map will be inserted here or pasted below -->
        {% include "us_map.svg" %}
    </div>
    <div id="stations-list-display">
        <h3>Select a State</h3>
        <p>Tap or hover on a state to see available stations.</p>
    </div>
</div>

<!-- Floating hovercard for desktop -->
<div id="map-hovercard" role="tooltip" aria-live="polite">
    <button id="map-hovercard-close" aria-label="Close">&times;</button>
    <div id="map-hovercard-content"></div>
</div>

<script id="loe-stations-data" type="application/json">{{ { stations: stations.stations, zipCoords: zipCoords } | dump | safe }}</script>
<script>
    (function () {
        const dataEl = document.getElementById('loe-stations-data');
        if (!dataEl) return;
        let data;
        try { data = JSON.parse(dataEl.textContent); } catch (e) { return; }
        const stations = data.stations || [];
        const zipCoords = data.zipCoords || {};

        const input = document.getElementById('zip-input');
        const results = document.getElementById('zip-finder-results');
        if (!input || !results) return;

        // Haversine, returns km. Inputs in degrees.
        function distance(a, b) {
            const toRad = d => d * Math.PI / 180;
            const dLat = toRad(b[0] - a[0]);
            const dLng = toRad(b[1] - a[1]);
            const sa = Math.sin(dLat / 2) ** 2 +
                Math.cos(toRad(a[0])) * Math.cos(toRad(b[0])) * Math.sin(dLng / 2) ** 2;
            return 12742 * Math.asin(Math.sqrt(sa));
        }

        function renderStations(list) {
            if (!list.length) return '<p>No stations listed.</p>';
            return '<ul>' + list.map(s => {
                const freq = s.frequency ? ' ' + s.frequency : '';
                const sched = s.schedule ? ' &mdash; ' + s.schedule : '';
                return `<li><a href="${s.url}">${s.city}, ${s.state}: ${s.callsign}${freq}</a>${sched}</li>`;
            }).join('') + '</ul>';
        }

        function lookup(zip) {
            const prefix = zip.slice(0, 3);
            const origin = zipCoords[prefix];
            if (!origin) {
                results.innerHTML = '<p class="zip-note">No match for that zip code. Try the map below.</p>';
                return;
            }
            // Score every station with coords; nationwide nearest by Haversine.
            const scored = stations
                .filter(s => Array.isArray(s.coords))
                .map(s => ({ s, d: distance(origin, s.coords) }))
                .sort((a, b) => a.d - b.d);
            if (!scored.length) {
                results.innerHTML = `<p>No nearby stations found for that zip code.</p>`;
                return;
            }
            const picks = scored.slice(0, 3).map(x => x.s);
            results.innerHTML = `<h4>Nearest stations</h4>` + renderStations(picks);
        }

        input.addEventListener('input', function () {
            const v = input.value.replace(/\D/g, '').slice(0, 5);
            if (v !== input.value) input.value = v;
            if (v.length === 5) {
                lookup(v);
            } else if (v.length === 0) {
                results.innerHTML = '';
            }
        });
    })();
</script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const stationMap = {};
        const articleContent = document.querySelector('.article-content');

        if (articleContent) {
            const headings = articleContent.querySelectorAll('h2');
            headings.forEach(h2 => {
                const stateName = h2.textContent.trim();
                // Find the next UL
                let nextElem = h2.nextElementSibling;
                while (nextElem && nextElem.tagName !== 'UL' && nextElem.tagName !== 'H2') {
                    nextElem = nextElem.nextElementSibling;
                }

                if (nextElem && nextElem.tagName === 'UL') {
                    stationMap[stateName] = nextElem.outerHTML;
                    // Optionally hide the original list if we only want map interaction
                    // h2.style.display = 'none';
                    // nextElem.style.display = 'none';
                }
            });
        }

        const mapSvg = document.querySelector('#stations-map-container svg');
        const displayDiv = document.getElementById('stations-list-display');

        // Hovercard elements
        const hovercard = document.getElementById('map-hovercard');
        const hovercardContent = document.getElementById('map-hovercard-content');
        const hovercardClose = document.getElementById('map-hovercard-close');

        // Detect desktop hover-capable environment
        const isDesktopHover = () =>
            window.matchMedia('(hover: hover) and (min-width: 701px)').matches;

        let cardPinned = false;
        let lastMouseX = 0;
        let lastMouseY = 0;

        function positionCard(x, y) {
            const cardW = hovercard.offsetWidth || 280;
            const cardH = hovercard.offsetHeight || 200;
            const margin = 16;
            const vw = window.innerWidth;
            const vh = window.innerHeight;

            let left = x + 14;
            let top = y + 14;

            if (left + cardW + margin > vw) left = x - cardW - 14;
            if (top + cardH + margin > vh) top = y - cardH - 14;
            if (left < margin) left = margin;
            if (top < margin) top = margin;

            hovercard.style.left = left + 'px';
            hovercard.style.top = top + 'px';
        }

        function showHovercard(stateName, x, y) {
            const html = stationMap[stateName]
                ? `<h3>${stateName}</h3>${stationMap[stateName]}`
                : `<h3>${stateName}</h3><p>No stations listed.</p>`;
            hovercardContent.innerHTML = html;
            hovercard.classList.add('visible');
            positionCard(x, y);
        }

        function hideHovercard() {
            hovercard.classList.remove('visible');
            cardPinned = false;
        }

        if (hovercardClose) {
            hovercardClose.addEventListener('click', function (e) {
                e.stopPropagation();
                hideHovercard();
            });
        }

        // Click away dismisses pinned card
        document.addEventListener('click', function (e) {
            if (cardPinned && !hovercard.contains(e.target)) {
                hideHovercard();
            }
        });

        if (mapSvg) {
            // Add ID to svg if missing for CSS specificity
            mapSvg.id = 'us-map-svg';

            // Select both paths and circles (for DC)
            const paths = mapSvg.querySelectorAll('path, circle');
            const classToStateName = {};

            // Create highlight layer group (for z-index handling without DOM reordering)
            const highlightGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
            highlightGroup.setAttribute('id', 'highlight-overlay');
            highlightGroup.style.pointerEvents = 'none'; // Critical for anti-flicker
            mapSvg.appendChild(highlightGroup);

            // Pass 1: Find state names for classes
            paths.forEach(path => {
                const title = path.querySelector('title');
                const pathClass = path.getAttribute('class');
                if (title && pathClass) {
                    const stateName = title.textContent.trim();
                    const classes = pathClass.split(/\s+/);
                    classes.forEach(cls => {
                        // Strict check: only 2-letter codes or specific ignored classes
                        if (cls && cls.length === 2 && !['st', 'bo', 'se'].includes(cls.toLowerCase())) {
                            classToStateName[cls] = stateName;
                        }
                    });
                }
            });

            // Pass 2: Assign data-state-name and add listeners
            paths.forEach(path => {
                // Find state name from classes
                let stateName = null;
                const pathClass = path.getAttribute('class');

                if (pathClass) {
                    const classes = pathClass.split(/\s+/);
                    for (const cls of classes) {
                        if (classToStateName[cls]) {
                            stateName = classToStateName[cls];
                            break;
                        }
                    }
                }

                if (!stateName) {
                    const title = path.querySelector('title');
                    if (title) {
                        stateName = title.textContent.trim();
                    }
                }

                // Exclude borders and separators explicitly
                if (stateName && pathClass && !pathClass.includes('borders') && !pathClass.includes('separator')) {

                    // Assign unique ID if missing (needed for <use> href)
                    if (!path.id) {
                        path.id = 'map-path-' + Math.random().toString(36).substr(2, 9);
                    }

                    path.setAttribute('data-state-name', stateName);

                    const clearHighlight = () => {
                        while (highlightGroup.firstChild) {
                            highlightGroup.removeChild(highlightGroup.firstChild);
                        }
                    };

                    const highlightState = (name) => {
                        const safeStateName = name.replace(/"/g, '\\"');
                        const stateParts = mapSvg.querySelectorAll(`[data-state-name="${safeStateName}"]`);

                        clearHighlight();

                        stateParts.forEach(part => {
                            const clone = part.cloneNode(true);
                            clone.removeAttribute('id');
                            clone.removeAttribute('class');

                            const hlColor = getComputedStyle(document.documentElement).getPropertyValue('--map-highlight').trim() || '#88BDBD';
                            clone.style.setProperty('fill', hlColor, 'important');
                            clone.style.setProperty('stroke', '#ffffff', 'important');
                            clone.style.setProperty('stroke-width', '1px', 'important');
                            clone.style.pointerEvents = 'none';
                            clone.classList.add('state_highlight');

                            highlightGroup.appendChild(clone);
                        });
                    };

                    // Desktop hover
                    path.addEventListener('mouseenter', function (e) {
                        if (!isDesktopHover()) return;
                        if (cardPinned) return; // don't hijack pinned card on hover
                        highlightState(stateName);
                        showHovercard(stateName, e.clientX, e.clientY);
                        lastMouseX = e.clientX;
                        lastMouseY = e.clientY;
                    });

                    path.addEventListener('mousemove', function (e) {
                        if (!isDesktopHover()) return;
                        if (cardPinned) return;
                        lastMouseX = e.clientX;
                        lastMouseY = e.clientY;
                        positionCard(e.clientX, e.clientY);
                    });

                    path.addEventListener('mouseleave', function () {
                        if (!isDesktopHover()) return;
                        if (cardPinned) return;
                        clearHighlight();
                        hideHovercard();
                    });

                    // Click handler
                    path.addEventListener('click', function (e) {
                        e.stopPropagation();
                        if (isDesktopHover()) {
                            // Desktop: pin the hovercard
                            highlightState(stateName);
                            showHovercard(stateName, e.clientX, e.clientY);
                            cardPinned = true;
                        } else {
                            // Mobile/touch: populate the static display div
                            highlightState(stateName);
                            if (stationMap[stateName]) {
                                displayDiv.innerHTML = `<h3>${stateName}</h3>${stationMap[stateName]}`;
                            } else {
                                displayDiv.innerHTML = `<h3>${stateName}</h3><p>No stations listed.</p>`;
                            }
                        }
                    });
                }
            });
        }
    });
</script>
